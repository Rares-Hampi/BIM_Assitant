# Development Dockerfile for Backend with hot-reload
FROM node:20-alpine

WORKDIR /app

# Install nodemon globally for hot-reload
RUN npm install -g nodemon

# Create necessary directories
RUN mkdir -p uploads output_web new/output_web

# Expose port
EXPOSE 3000

# Start script that installs dependencies then runs nodemon
CMD sh -c "npm install && npx prisma generate && nodemon --watch . --ext js,json index.js"
